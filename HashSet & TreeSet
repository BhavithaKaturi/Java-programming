import java.util.*;

class SetDemo {
    public static void main(String[] args) {
        HashSet<Integer> hs = new HashSet<>();
        hs.add(3); hs.add(1);

        TreeSet<Integer> ts = new TreeSet<>();
        ts.add(3); ts.add(1);

        System.out.println(hs);
        System.out.println(ts);
    }
}
