class Pangram {
    public static void main(String[] args) {
        String str = "abcdefghijklmnopqrstuvwxyz";
        str = str.toLowerCase();

        boolean flag = true;

        for (char c = 'a'; c <= 'z'; c++) {
            if (str.indexOf(c) == -1) {
                flag = false;
                break;
            }
        }

        if (flag)
            System.out.println("Pangram");
        else
            System.out.println("Not Pangram");
    }
}
