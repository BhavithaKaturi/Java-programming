class MaxMin {
    public static void main(String[] args) {
        int[] arr = {10, 20, 5, 40};

        int max = arr[0], min = arr[0];

        for (int i : arr) {
            if (i > max) max = i;
            if (i < min) min = i;
        }

        System.out.println("Max=" + max);
        System.out.println("Min=" + min);
    }
}
