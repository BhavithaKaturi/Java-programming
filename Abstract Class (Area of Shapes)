abstract class Shape {
    abstract void area();
}

class Circle extends Shape {
    void area() {
        System.out.println("Area of Circle = " + (3.14 * 5 * 5));
    }
}

class Rectangle extends Shape {
    void area() {
        System.out.println("Area of Rectangle = " + (5 * 4));
    }
}

class Main {
    public static void main(String[] args) {
        Shape s;
        s = new Circle();
        s.area();

        s = new Rectangle();
        s.area();
    }
}
